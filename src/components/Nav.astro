---
import { MARCA, URLS } from '../constants';

interface Props {
  /** 'home' mostra os links de navegação | 'especialidade' mostra o link de voltar */
  variant?: 'home' | 'especialidade';
}

const { variant = 'home' } = Astro.props;
---

<nav>
  <div class="nav-inner">
    <a class="logo" href="/">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C8.5 2 6 5 6 8c0 2.2.8 4 2 5.5V20c0 1.1.9 2 2 2h4c1.1 0 2-.9 2-2v-6.5c1.2-1.5 2-3.3 2-5.5 0-3-2.5-6-6-6z"/>
        </svg>
      </div>
      <span class="logo-text">Odonto<span>Maringá</span></span>
    </a>

    {variant === 'home' && (
      <>
        <!-- Desktop links -->
        <ul class="nav-links">
          <li><a href="#especialidades">Especialidades</a></li>
          <li><a href="#como-funciona">Como Funciona</a></li>
          <li><a href="#depoimentos">Depoimentos</a></li>
          <li><a href="#contato" class="btn-nav">Solicitar Contato</a></li>
        </ul>

        <!-- Hamburguer mobile -->
        <button class="nav-menu-btn" aria-label="Abrir menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </>
    )}

    {variant === 'especialidade' && (
      <div class="nav-right">
        <a href="/" class="nav-back">
          <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
          Voltar ao início
        </a>
        <a href="#contato" class="btn-nav">Solicitar Contato</a>
      </div>
    )}
  </div>
</nav>

<!-- Mobile drawer (só na home) -->
{variant === 'home' && (
  <div class="nav-drawer">
    <a href="#especialidades">Especialidades</a>
    <a href="#como-funciona">Como Funciona</a>
    <a href="#depoimentos">Depoimentos</a>
    <a href="#contato" class="btn-nav">Solicitar Contato</a>
  </div>
)}